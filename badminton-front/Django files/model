from django.db import models

class Player(models.Model):
    id = models.AutoField(primary_key=True)
    name = models.CharField(max_length=100)
    country = models.CharField(max_length=100)
    country_code = models.CharField(max_length=3)
    photo_url = models.URLField(blank=True)

    def __str__(self):
        return self.name

class Sponsor(models.Model):
    name = models.CharField(max_length=100)
    logo_url = models.URLField()

    def __str__(self):
        return self.name

class Match(models.Model):
    id = models.AutoField(primary_key=True)
    tournament = models.CharField(max_length=200)
    match_type = models.CharField(max_length=100)
    player1 = models.ForeignKey(Player, related_name='player1_matches', on_delete=models.CASCADE)
    player2 = models.ForeignKey(Player, related_name='player2_matches', on_delete=models.CASCADE)
    status = models.CharField(max_length=20, choices=[('Live', 'Live'), ('Completed', 'Completed'), ('Upcoming', 'Upcoming')])
    server_id = models.IntegerField()  # ID of the serving player
    game1_player1 = models.IntegerField(default=0)
    game1_player2 = models.IntegerField(default=0)
    game2_player1 = models.IntegerField(default=0)
    game2_player2 = models.IntegerField(default=0)
    game3_player1 = models.IntegerField(default=0)
    game3_player2 = models.IntegerField(default=0)
    current_game = models.IntegerField(default=1)
    player1_sets = models.IntegerField(default=0)
    player2_sets = models.IntegerField(default=0)

    def __str__(self):
        return f"{self.tournament} - {self.player1} vs {self.player2}"